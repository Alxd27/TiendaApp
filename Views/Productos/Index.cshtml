@model IEnumerable<TiendaApp.Models.Producto>

@{
    ViewData["Title"] = "Listado de Productos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Lista de Productos - Tienda "La Económica"</h1>
        <a asp-action="Create" class="btn btn-primary">Crear Nuevo Producto</a>
    </div>

    <table class="table table-striped table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Stock</th>
                <th>Vencimiento</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center">No hay productos registrados aún.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model) {
                    <tr>
                        <td>@item.Nombre</td>
                        <td>@item.Precio.ToString("C")</td>
                        <td>@item.Stock</td>
                        <td>@item.FechaVencimiento.ToShortDateString()</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>